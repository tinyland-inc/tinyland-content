{
  "name": "@tummycrypt/tinyland-content",
  "version": "0.1.0",
  "description": "Content management services for markdown-based content with versioning, scheduling, and relationship resolution",
  "type": "module",
  "license": "Zlib AND LicenseRef-Tinyland-Proprietary",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./loaders": {
      "types": "./dist/loaders/index.d.ts",
      "import": "./dist/loaders/index.js"
    },
    "./versioning": {
      "types": "./dist/versioning/index.d.ts",
      "import": "./dist/versioning/index.js"
    },
    "./scheduling": {
      "types": "./dist/scheduling/index.d.ts",
      "import": "./dist/scheduling/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tummycrypt/tinyland-content-types": "workspace:*",
    "gray-matter": "^4.0.3",
    "nanoid": "^5.0.0",
    "diff": "^7.0.0"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.2.4",
    "@types/diff": "^6.0.0",
    "@types/node": "^22.0.0",
    "fast-check": "^4.3.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "node-cron": ">=3.0.0",
    "date-fns-tz": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "node-cron": {
      "optional": true
    },
    "date-fns-tz": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tinyland-inc/tinyland.dev",
    "directory": "packages/tinyland-content"
  }
}
